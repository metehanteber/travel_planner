@using TravelPlanner.UI.Helpers
@{
    var _layoutData = UIHelper.GetLayoutData();
    var colors = UIHelper.GetUIColors();

    string mainTitle = ViewData["Title"] is null ? "" : ((string)(ViewData["Title"] ?? "")).Trim();
    if (mainTitle != "") mainTitle += " | ";
    mainTitle += "Seyahat Asistanı";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@mainTitle</title>

    <link type="text/css" href="/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link type="text/css" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link type="text/css" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link type="text/css" rel="stylesheet" href="/css/site.css" />

    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f7f6;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .custom-navbar {
            background-color: white !important;
            background-size: 60px;
            background-repeat: repeat-x;
            background-position: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
            transition: all 0.3s ease;
        }

        .navbar-brand-text {
            background: white;
            -webkit-background-clip: content-box;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #bd1919 !important;
        }

        .nav-link {
            font-weight: 600;
            font-size: 1.2rem;
            color: #bd1919 !important;
            transition: all 0.2s ease;
            position: relative;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
        }

            .nav-link:hover {
                color: #93c5fd !important;
                background-color: rgba(255, 255, 255, 0.05);
            }

        .custom-dropdown {
            border: none;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
            border-radius: 12px;
            padding: 0.5rem 0;
            max-height: 350px;
            overflow-y: auto;
            z-index: 1050;
            background-color: #ffffff;
        }

            .custom-dropdown::-webkit-scrollbar {
                width: 6px;
            }

            .custom-dropdown::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 10px;
            }

            .custom-dropdown::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

                .custom-dropdown::-webkit-scrollbar-thumb:hover {
                    background: #94a3b8;
                }

            .custom-dropdown .dropdown-item {
                padding: 0.7rem 1.5rem;
                font-weight: 500;
                color: #334155;
                transition: all 0.2s;
                border-left: 3px solid transparent;
            }

                .custom-dropdown .dropdown-item:hover {
                    background-color: #f8fafc;
                    color: #2563eb;
                    border-left: 3px solid #3b82f6;
                }

        .footer-modern {
            background-color: #ffffff;
            box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.03);
            margin-top: auto;
        }

        .footer-link {
            color: #64748b;
            text-decoration: none;
            transition: color 0.2s ease;
        }

            .footer-link:hover {
                color: #3b82f6;
            }

        .social-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #f1f5f9;
            color: #475569;
            transition: all 0.3s ease;
        }

            .social-icon:hover {
                background-color: #3b82f6;
                color: #ffffff;
                transform: translateY(-4px) scale(1.05);
                box-shadow: 0 10px 15px rgba(59, 130, 246, 0.3);
            }

        #scrollTopBtn {
            display: none;
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 99;
            border: none;
            outline: none;
            background-color: #3b82f6;
            color: white;
            cursor: pointer;
            padding: 15px;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }

            #scrollTopBtn:hover {
                background-color: #1d4ed8;
                transform: translateY(-3px);
            }
    </style>
</head>
<body style="margin-bottom: 0px !important;">

    <header style="z-index: 99999999;">
        <nav class="navbar navbar-expand-lg fixed-top custom-navbar py-2">
            <div class="container" style="padding: 10px;">

                <a class="navbar-brand d-flex align-items-center" href="/">
                    <div class="bg-white bg-opacity-10 text-white rounded p-2 me-2 d-flex align-items-center justify-content-center" style="backdrop-filter: blur(5px);">
                        <i class="fa-solid fa-earth-americas fs-5"></i>
                    </div>
                    <span class="navbar-brand-text fs-4">Seyahat Asistanı</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none bg-white bg-opacity-25" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="fa-solid fa-house fa-sm me-1"></i> Ana Sayfa
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="javascript:void(0);" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-solid fa-map-location-dot fa-sm me-1"></i> Ülkeler
                            </a>
                            <ul class="dropdown-menu custom-dropdown mt-2" aria-labelledby="navbarDropdown">
                                @for (int i = 0; i < _layoutData.Countries.Count; i++)
                                {
                                    var country = _layoutData.Countries[i];

                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" href="/country/@country.Code.ToLower().Replace("ı", "i")">
                                            <img src="/images/flags/@(country.Code.ToLower()).jpg"
                                                 alt="@country.Name Bayrağı"
                                                 class="me-3 rounded shadow-sm"
                                                 style="height: 18px; width: 26px; object-fit: cover;" />
                                            @country.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/forecast">
                                <i class="fa-solid fa-chart-line fa-sm me-1"></i> Tahminler
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container" id="main-container" style="margin-top: 110px !important;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-modern py-5 mt-auto">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-5 col-md-6">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-2 d-flex align-items-center justify-content-center">
                            <i class="fa-solid fa-earth-americas fs-5"></i>
                        </div>
                        <span class="fs-4 fw-bolder text-dark">Seyahat Asistanı</span>
                    </div>
                    <p class="text-muted pe-lg-5 lh-lg fs-6">
                        Yapay zeka modelleri ile desteklenen platformumuz sayesinde turizm verilerini analiz edin, geleceğin rotalarını bugünden keşfedin ve seyahat bütçenizi en iyi şekilde optimize edin.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold text-dark mb-4">Hızlı Bağlantılar</h5>
                    <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                        <li><a href="/" class="footer-link fw-medium"><i class="fa-solid fa-angle-right fa-sm me-2 text-primary"></i>Ana Sayfa</a></li>
                        <li><a href="/forecast" class="footer-link fw-medium"><i class="fa-solid fa-angle-right fa-sm me-2 text-primary"></i>Yapay Zeka Tahminleri</a></li>
                        <li><a href="/#destinasyonlar" class="footer-link fw-medium"><i class="fa-solid fa-angle-right fa-sm me-2 text-primary"></i>Popüler Rotalar</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-12 text-lg-end">
                    <h5 class="fw-bold text-dark mb-4">Bizi Takip Edin</h5>
                    <div class="d-flex justify-content-lg-end gap-3 mb-4">
                        <a href="#" class="social-icon"><i class="fa-brands fa-github fs-5"></i></a>
                        <a href="#" class="social-icon"><i class="fa-brands fa-linkedin-in fs-5"></i></a>
                        <a href="#" class="social-icon"><i class="fa-brands fa-x-twitter fs-5"></i></a>
                        <a href="#" class="social-icon"><i class="fa-brands fa-instagram fs-5"></i></a>
                    </div>
                    <p class="text-muted small mb-0 fw-medium">
                        &copy; @DateTime.Now.Year - Seyahat Asistanı. Tüm hakları saklıdır.
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <button onclick="scrollToTop()" id="scrollTopBtn" title="Yukarı Çık">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    <script type="text/javascript" src="/lib/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script type="text/javascript">
        $(document).ready(function() {
            loadContainerResizer();
        });

        function resizeContainer() {
            let c = document.getElementById('main-container');
            c.style.minHeight = (innerHeight - 150).toString() + "px";
        }

        function loadContainerResizer() {
            window.onresize = function() {
                resizeContainer();
            }
            setTimeout(resizeContainer, 0);
        }

        window.onscroll = function() { scrollFunction() };

        function scrollFunction() {
            let btn = document.getElementById("scrollTopBtn");
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                btn.style.display = "block";
            } else {
                btn.style.display = "none";
            }
        }

        function scrollToTop() {
            window.scrollTo({top: 0, behavior: 'smooth'});
        }
    </script>
</body>
</html>
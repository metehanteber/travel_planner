@model List<TravelPlanner.Data.Entities.Country>
@{
    ViewData["Title"] = "Tahmin Raporları";
}

<div class="row mt-4 mb-4">
    <div class="col-12">
        <h2 class="fw-bold"><i class="fa-solid fa-chart-line text-primary me-2"></i> Zaman Serisi Tahminleri</h2>
        <p class="text-muted">Türkiye, İspanya, Norveç ve Rusya için ARIMA & LSTM hibrit model tahmin sonuçları.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <form id="filterForm" class="row g-3 align-items-end">

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Ülke Seçin</label>
                        <select class="form-select rounded-3" id="countrySelect" name="countryId">
                            <option value="0" selected>-- Seçilmedi --</option>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var country in Model)
                                {
                                    <option value="@country.Id">@country.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Veri Tipi (Metrik)</label>
                        <select class="form-select rounded-3" id="metricSelect" name="metricType">
                            <option value="TouristCount" selected>Turist Sayısı (Tahmini)</option>
                            <option value="AccommodationPrice">Ortalama Konaklama Fiyatı</option>
                            <option value="Inflation">Enflasyon Beklentisi</option>
                            <option value="ExchangeRate">Döviz Kuru</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Veri Dönemi</label>
                        <div class="row">
                            <div class="col-md-12">
                                <input type="checkbox" onchange="setDataType();" id="chkDataTypePast" />
                                <label for="chkDataTypePast">Geçmiş Veriler</label>
                            </div>
                            <div class="col-md-12">
                                <input type="checkbox" onchange="setDataType();" id="chkDataTypeForecast" />
                                <label for="chkDataTypeForecast">Tahmin Verileri</label>
                            </div>
                            <input type="hidden" name="dataType" id="txtDataType" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <button type="button" id="btnGetir" class="btn btn-primary w-100 rounded-3">
                            <i class="fa-solid fa-magnifying-glass me-2"></i> Verileri Getir
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- Grafik Alanı -->
<div class="row mb-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold" id="chartTitle">Seçilen Kriterlere Göre Gelecek Projeksiyonu</h5>
            </div>
            <div class="card-body p-4">
                <div style="position: relative; height:400px; width:100%">
                    <canvas id="forecastChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script type="text/javascript">
        function setDataType() {
            let pst = document.getElementById('chkDataTypePast');
            pst = pst ? pst.checked : false;
            let frc = document.getElementById('chkDataTypeForecast');
            frc = frc ? frc.checked : false;
            let dt = document.getElementById('txtDataType');
            if(frc && pst) dt.value = "2";
            else if (frc) dt.value = "1";
            else if(pst) dt.value = "0";
        }
    </script>


    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let myChart = null;

        $(document).ready(function () {
            renderChart(["Kış", "İlkbahar", "Yaz", "Sonbahar"], [0, 0, 0, 0], "Veri Bekleniyor...");
            $("#btnGetir").click(function () {
                let countryId = $("#countrySelect").val();
                let metricType = $("#metricSelect").val();
                let dataType = $("#txtDataType").val();

                if(countryId == "0") {
                    alert("Lütfen bir ülke seçiniz!");
                    return;
                }
        $.ajax({
            url: '/Forecast/GetForecastData',
            type: 'POST',
            data: { countryId: countryId, metricType: metricType, dataType: dataType },
            success: function (res) {
                if(res.isSuccess) {
                    let labelName = $("#metricSelect option:selected").text();
                    renderChart(res.labels, res.values, labelName);
                } else {
                    renderChart(["Veri Yok"], [0], "Sonuç Bulunamadı");
                    alert(res.message);
                }
            },
            error: function () {
                alert("İşlem sırasında bir hata oluştu.");
            }
        });
            });
        });

        function renderChart(labelsArray, dataArray, labelName) {
            const ctx = document.getElementById('forecastChart').getContext('2d');

            if (myChart != null) {
                myChart.destroy();
            }

            let gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(13, 110, 253, 0.5)');
            gradient.addColorStop(1, 'rgba(13, 110, 253, 0.0)');

            myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labelsArray,
                    datasets: [{
                        label: labelName,
                        data: dataArray,
                        borderColor: '#0d6efd',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#0d6efd',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        }
    </script>
}
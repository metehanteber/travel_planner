@using TravelPlanner.Data.Entities
@model List<Country>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="row mb-4 mt-3">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4" style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%); color: white;">
            <div class="card-body p-5">
                <h1 class="display-5 fw-bold"><i class="fa-solid fa-plane-departure me-3"></i>Turizm Planlayıcı</h1>
                <p class="lead mt-3">
                    Ülkelerin turizm, döviz ve enflasyon verilerini analiz edin.
                </p>
                <a href="/Forecast" class="btn btn-light btn-lg text-primary fw-bold rounded-pill mt-2 shadow-sm">
                    <i class="fa-solid fa-chart-line"></i> Tahminler <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mb-5">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-shrink-0 bg-primary bg-opacity-10 p-3 rounded-4">
                    <i class="fa-solid fa-earth-europe fa-2x text-primary"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted mb-0">Ülke Sayısı</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.CountryCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-shrink-0 bg-success bg-opacity-10 p-3 rounded-4">
                    <i class="fa-solid fa-city fa-2x text-success"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted mb-0">Şehir Sayısı</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.CityCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center">
                <div class="flex-shrink-0 bg-warning bg-opacity-10 p-3 rounded-4">
                    <i class="fa-solid fa-brain fa-2x text-warning"></i>
                </div>
                <div class="flex-grow-1 ms-3">
                    <h6 class="text-muted mb-0">Tahmin Sayısı</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.ForecastCount</h2>
                </div>
            </div>
        </div>
    </div>
</div>
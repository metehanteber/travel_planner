@model TravelPlanner.Data.Entities.Country
@{
    ViewData["Title"] = Model.Name + " - Genel Turizm Bakışı";
    var cities = ViewBag.Cities as List<TravelPlanner.Data.Entities.City>;
    var latestMetrics = ViewBag.LatestMetrics as Dictionary<long, TravelPlanner.Data.Entities.TourismMetric>;
}

<div class="bg-light py-5 border-bottom mb-5" style="background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bolder d-flex align-items-center text-dark mb-3">
                    <img src="/images/flags/@(Model.Code.ToLower()).jpg"
                         alt="@Model.Name Bayrağı"
                         class="me-3 rounded shadow"
                         style="height: 1.1em; width: auto; object-fit: cover; border: 3px solid white;" />
                    @Model.Name
                </h1>
                <p class="text-secondary fs-5 mb-0">Ülke genelindeki makroekonomik eğilimleri ve turistik bölgelerin potansiyellerini yapay zeka gücüyle keşfedin.</p>
            </div>
            <div class="col-md-4 text-end mt-4 mt-md-0">
                <div class="card shadow border-0 bg-white" style="border-radius: 15px;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="text-muted fw-bold mb-0 text-uppercase tracking-wide">Güncel Kur Paritesi</h6>
                            <span class="badge bg-primary text-white">EUR / @ViewBag.Currency</span>
                        </div>
                        <h2 class="mb-3 text-dark fw-bolder">
                            @ViewBag.LatestExchangeRate
                        </h2>
                        <div class="alert alert-info border-0 py-2 px-3 mb-0 fs-7 d-flex align-items-start">
                            <i class="fa-solid fa-robot mt-1 me-2 text-primary"></i>
                            <small>@ViewBag.ExchangeInsight</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">

    @if (!string.IsNullOrWhiteSpace(Model.AboutContent))
    {
        <div class="card border-0 shadow-sm mb-5" style="border-radius: 15px; background: #fff;">
            <div class="card-body p-4">
                <h3 class="fw-bold text-dark mb-3"><i class="fa-solid fa-circle-info text-primary me-2"></i> Ülke Hakkında Genel Bilgiler</h3>
                <div class="text-secondary lh-lg">
                    <br />
                    <img src="/images/countries/@(Model.Id).jpg" style="width: 100%; height: auto;" />
                    <br />
                    @Html.Raw(Model.AboutContent)
                </div>
            </div>
        </div>
    }

    <div class="d-flex align-items-center mb-4">
        <i class="fa-solid fa-map-location-dot fs-3 text-primary me-3"></i>
        <h2 class="fw-bold mb-0">Öne Çıkan Destinasyonlar</h2>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @if (cities != null && cities.Any())
        {
            foreach (var city in cities)
            {
                var metric = latestMetrics != null && latestMetrics.ContainsKey(city.Id) ? latestMetrics[city.Id] : null;

                <div class="col">
                    <div class="card h-100 shadow-sm border-0 city-card" style="border-radius: 15px; overflow: hidden;">
                        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                            <h4 class="card-title fw-bold text-dark">@city.Name</h4>
                        </div>
                        <div class="card-body">
                            <div class="p-3 bg-light rounded-3 mb-4">
                                @if (metric != null)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-secondary"><i class="fa-solid fa-users fa-fw me-1"></i> Turist Hacmi</span>
                                        <span class="fw-bold text-dark">@(metric.TouristCount?.ToString("N0") ?? "-")</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-secondary"><i class="fa-solid fa-bed fa-fw me-1"></i> Ort. Fiyat</span>
                                        <span class="fw-bold text-success">@(metric.AvgAccommodationPrice?.ToString("N2") ?? "-") @metric.CurrencyUsed</span>
                                    </div>
                                    <hr class="my-2 bg-secondary opacity-25">
                                    <div class="text-end text-muted" style="font-size: 0.75rem;">
                                        Güncelleme: @metric.DateRecorded.ToString("MMM yyyy")
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-3 text-muted">
                                        <i class="fa-solid fa-hourglass-half mb-2 fs-5"></i><br />
                                        Veriler analiz ediliyor...
                                    </div>
                                }
                            </div>
                            <a href="/city/@city.Id" class="btn btn-primary w-100 stretched-link fw-bold" style="border-radius: 10px;">
                                Destinasyonu İncele <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning border-0 shadow-sm rounded-3 w-100">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> Bu ülkeye ait kayıtlı destinasyon bulunmamaktadır.
            </div>
        }
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-white pt-4 pb-0 border-bottom-0 d-flex align-items-center">
            <i class="fa-solid fa-chart-area fs-4 text-primary me-2"></i>
            <h3 class="fw-bold mb-0">Demografik Büyüme Trendi</h3>
        </div>
        <div class="card-body p-4">
            <canvas id="populationChart" style="max-height: 400px;"></canvas>
        </div>
    </div>
</div>

<style>
    .city-card {
        transition: all 0.3s ease;
    }

        .city-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        }

    .tracking-wide {
        letter-spacing: 0.05em;
    }

    .fs-7 {
        font-size: 0.85rem;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var popData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PopulationData));
        var labels = Object.keys(popData);
        var data = Object.values(popData);

        var ctx = document.getElementById('populationChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Toplam Nüfus',
                    data: data,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.05)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#0d6efd',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,0.8)',
                        padding: 12,
                        callbacks: {
                            label: function(context) { return context.parsed.y.toLocaleString('tr-TR') + ' Kişi'; }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: false,
                        border: { display: false },
                        ticks: { callback: function(value) { return value.toLocaleString('tr-TR'); } }
                    }
                }
            }
        });
    </script>
}
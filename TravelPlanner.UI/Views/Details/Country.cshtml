@model TravelPlanner.Data.Entities.Country
@{
    ViewData["Title"] = Model.Name;
    var cities = ViewBag.Cities as List<TravelPlanner.Data.Entities.City>;
    var latestMetrics = ViewBag.LatestMetrics as Dictionary<long, TravelPlanner.Data.Entities.TourismMetric>;
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold d-flex align-items-center">
                <img src="/images/flags/@(Model.Code.ToLower()).jpg"
                     alt="@Model.Name Bayrağı"
                     class="me-3 rounded shadow-sm"
                     style="height: 1.2em; width: auto; object-fit: cover;" />
                @Model.Name
            </h1>
            <p class="text-muted fs-5 mt-2">Ülke ve bağlı bölgelere ait istatistikler</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body">
                    <h6 class="text-muted mb-1">Güncel Kur (EUR -> @ViewBag.Currency)</h6>
                    <h3 class="mb-0 text-success fw-bold">
                        <i class="fa-solid fa-money-bill-trend-up me-1"></i> @ViewBag.LatestExchangeRate
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <hr class="mb-4" />
    <h3 class="mb-3"><i class="fa-solid fa-chart-area me-2"></i>Yıllara Göre Nüfus</h3>
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body">
            <canvas id="populationChart" style="max-height: 400px;"></canvas>
        </div>
    </div>
    <hr class="mb-4" />
    <h3 class="mb-3"><i class="fa-solid fa-map-location-dot me-2"></i> Şehirler & Bölgeler</h3>

    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @if (cities != null && cities.Any())
        {
            foreach (var city in cities)
            {
                var metric = latestMetrics != null && latestMetrics.ContainsKey(city.Id) ? latestMetrics[city.Id] : null;

                <div class="col">
                    <div class="card h-100 shadow-sm border-0 city-card transition-hover">
                        <div class="card-body">
                            <h4 class="card-title fw-bold">@city.Name</h4>

                            <div class="text-muted small mb-4 mt-2">
                                @if (metric != null)
                                {
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="fa-solid fa-users fa-fw me-2 text-primary"></i>
                                        <span><strong>@(metric.TouristCount?.ToString("N0") ?? "-")</strong> Turist</span>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <i class="fa-solid fa-bed fa-fw me-2 text-primary"></i>
                                        <span><strong>@(metric.AvgAccommodationPrice?.ToString("N2") ?? "-")</strong> @metric.CurrencyUsed / Gece</span>
                                    </div>
                                    <div class="text-muted mt-2" style="font-size: 0.75rem;">
                                        <i class="fa-regular fa-clock me-1"></i> <b>Veri Tarihi:</b> @metric.DateRecorded.ToString("MMMM yyyy")
                                    </div>
                                }
                                else
                                {
                                    <span class="fst-italic"><i class="fa-solid fa-hourglass-half me-1"></i> Veriler analiz ediliyor...</span>
                                }
                            </div>

                            <a href="/city/@city.Id" class="btn btn-outline-primary w-100 stretched-link">
                                Detaylar <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">Bu ülkeye ait kayıtlı şehir/bölge bulunmamaktadır.</div>
            </div>
        }
    </div>

</div>

<style>
    .city-card {
        transition: transform 0.2s ease-in-out;
    }

        .city-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var popData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.PopulationData));

        var labels = Object.keys(popData);
        var data = Object.values(popData);

        var ctx = document.getElementById('populationChart').getContext('2d');
        var myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Toplam Nüfus',
                    data: data,
                    borderColor: 'rgba(13, 110, 253, 1)',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: 'rgba(13, 110, 253, 1)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.parsed.y.toLocaleString('tr-TR') + ' Kişi';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString('tr-TR');
                            }
                        }
                    }
                }
            }
        });
    </script>
}